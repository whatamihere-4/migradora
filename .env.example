# =============================================================================
# Migradora — Gofile → Filester Mirror
# Copy this file to .env and fill in your values.
# All services load this single file via docker-compose env_file.
# =============================================================================

# --- Gofile source ---
# Comma-separated public folder URLs from your free Gofile account
GOFILE_FOLDER_URLS=https://gofile.io/d/YOUR_FOLDER_ID,https://gofile.io/d/ANOTHER_ID
# Account token from https://gofile.io/myprofile (used for auth + traffic monitoring)
GOFILE_TOKEN=your_gofile_account_token
# Optional password for protected folders
GOFILE_PASSWORD=

# --- Filester destination ---
# API key from Filester account settings
FILESTER_API_KEY=your_filester_api_key
FILESTER_API_BASE=https://u1.filester.me
# Top-level folder name created on Filester for the mirror
FILESTER_ROOT_FOLDER_NAME=gofile-mirror
# Max bytes per upload part (9.5 GiB default, under Filester's 10 GB limit)
FILESTER_MAX_FILE_BYTES=10200547328

# --- Paths (container paths; do not change unless you remount volumes) ---
DOWNLOAD_DIR=/data/downloads
STATE_DIR=/data/state
LOG_DIR=/data/logs
DB_PATH=/data/state/queue.db

# --- Processing limits ---
# Process one file at a time on a 50 GB VPS
MAX_CONCURRENT_FILES=1
# Pause downloads when free disk drops below this (GB)
MIN_FREE_DISK_GB=5
# Compute SHA-256 after download (slower on large files)
VERIFY_HASH=false
# Reset stale downloading/uploading jobs after this many seconds
STALE_JOB_TIMEOUT_SEC=3600

# --- Retries & throttling ---
DOWNLOAD_MAX_RETRIES=5
DOWNLOAD_RETRY_DELAY_SEC=30
# 0 = unlimited; set e.g. 5000 for ~5 MB/s cap
DOWNLOAD_THROTTLE_KBPS=0
UPLOAD_MAX_RETRIES=5
UPLOAD_RETRY_DELAY_SEC=30
# Delay between Gofile folder API calls during discovery
DISCOVERY_DELAY_SEC=2

# --- Gofile traffic guard ---
# Pause when account traffic exceeds this (GB); free tier ~100 GB/month
GOFILE_TRAFFIC_PAUSE_GB=90
GOFILE_TRAFFIC_CHECK_INTERVAL_SEC=3600

# --- Filester storage guard ---
# Pause uploads when account storage exceeds this percentage
FILESTER_STORAGE_PAUSE_PCT=95

# --- VPN (optional, use with docker-compose.vpn.yml) ---
VPN_ENABLED=false
PIA_OPENVPN_USER=
PIA_OPENVPN_PASSWORD=
PIA_SERVER_REGION=Netherlands
VPN_ROTATE_ON_BAN=true

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
LOG_LEVEL=INFO

# --- Worker tuning ---
WORKER_POLL_INTERVAL_SEC=5
HEARTBEAT_INTERVAL_SEC=30
TZ=UTC
