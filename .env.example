# =============================================================================
# Migradora — Gofile → Filester (minimal)
# Premium transfer account (#2) reads shared folder links from source account (#1).
# Subscription or Pay-As-You-Go both work — same API token from myProfile.
# =============================================================================

# --- Gofile (premium transfer account #2) ---
# Token from https://gofile.io/myProfile (subscription or PAYG account)
GOFILE_TOKEN=
# Comma-separated shared folder URLs from your source account (account #1)
GOFILE_FOLDER_URLS=
# Only if folders are password-protected
GOFILE_PASSWORD=
# CDN mirror preference for downloads (France/EU VPS: eu). auto = API default order.
GOFILE_CDN_PREFER=eu
# Probe each mirror with a 2 MiB sample and pick the fastest (adds ~5–15s per file).
# GOFILE_CDN_PROBE=true
# Parallel Range connections per file (helps high-latency routes). Resume uses single stream.
# GOFILE_DOWNLOAD_CONNECTIONS=4

# --- Filester destination ---
FILESTER_API_KEY=
FILESTER_API_BASE=https://u1.filester.me
FILESTER_ROOT_FOLDER_NAME=VR
# Folder identifier from https://filester.me/f/XXXXXXXX (your VR folder)
FILESTER_ROOT_FOLDER_ID=
# Studio folders inside VR — apu-style JSON {folder_id: name} (copy config/filester-folders.json):
# FILESTER_FOLDERS_FILE=/data/state/filester-folders.json
# Set false to only use folders JSON + FILESTER_ROOT_FOLDER_ID (no API folder create):
FILESTER_AUTO_CREATE_FOLDERS=false
FILESTER_MAX_FILE_BYTES=10200547328
# Split mode for files over FILESTER_MAX_FILE_BYTES:
#   bytes — byte-range parts (cat to rejoin); default, lowest CPU
#   ffmpeg_slice — ffmpeg stream-copy one part at a time (playable parts, same disk peak as bytes)
# Split parts are auto-grouped into a subfolder named after the video (no extra setting).
FILESTER_SPLIT_MODE=bytes
# SPLITTER_FFMPEG_TIMEOUT_SEC=7200
# FFMPEG_BIN=ffmpeg
# FFPROBE_BIN=ffprobe

# --- Paths (container paths; mapped in docker-compose) ---
DOWNLOAD_DIR=/data/downloads
STATE_DIR=/data/state
LOG_DIR=/data/logs

# --- Limits ---
# Peak disk per job ≈ source file + one upload part + MIN_FREE_DISK_GB headroom.
# Max source file ≈ DISK_BUDGET_GB - MIN_FREE_DISK_GB - upload part size (~9.5 GiB).
MIN_FREE_DISK_GB=5
DISK_BUDGET_GB=45
# Optional hard cap (GiB). Leave 0 to derive from DISK_BUDGET_GB (~30 GiB with defaults above).
MAX_SOURCE_FILE_GB=0
AUTO_SKIP_OVERSIZED=true
STALE_JOB_TIMEOUT_SEC=3600
# 0 = disabled (Filester ~10 GB limit is per-file, not total account storage)
FILESTER_STORAGE_PAUSE_PCT=0

# --- Retries ---
DOWNLOAD_MAX_RETRIES=5
DOWNLOAD_RETRY_DELAY_SEC=30
# 0 = unlimited (check this is not set if downloads feel capped)
# DOWNLOAD_THROTTLE_KBPS=0
UPLOAD_MAX_RETRIES=5
UPLOAD_RETRY_DELAY_SEC=30
DISCOVERY_DELAY_SEC=2

# --- Web dashboard ---
# Port on host and inside container (change both by setting this once)
WEBUI_PORT=8080
LOG_LEVEL=INFO
WORKER_POLL_INTERVAL_SEC=5
TZ=UTC
