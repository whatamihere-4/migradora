# =============================================================================
# Migradora — Gofile → Filester Mirror (JDownloader2)
# Copy to .env and fill in your values.
# =============================================================================

# --- Gofile source ---
# Comma-separated folder or file URLs (JD2 Gofile plugin handles crawling)
GOFILE_FOLDER_URLS=https://gofile.io/d/YOUR_FOLDER_ID
# Optional password for protected Gofile folders
GOFILE_PASSWORD=

# --- JDownloader2 (local Deprecated API, no MyJDownloader cloud) ---
JD2_HOST=jdownloader
JD2_PORT=3128
JD2_WEBUI_PORT=5800
JD2_API_PORT=3128
# Path inside jdownloader container (mapped to ./data/downloads)
JD2_DOWNLOAD_DIR=/output
JD2_API_TIMEOUT_SEC=30
JD2_POLL_INTERVAL_SEC=5
JD2_CRAWL_TIMEOUT_SEC=600

# --- Filester destination ---
FILESTER_API_KEY=your_filester_api_key
FILESTER_API_BASE=https://u1.filester.me
FILESTER_ROOT_FOLDER_NAME=gofile-mirror
FILESTER_MAX_FILE_BYTES=10200547328

# --- Paths ---
DOWNLOAD_DIR=/data/downloads
STATE_DIR=/data/state
LOG_DIR=/data/logs
DB_PATH=/data/state/queue.db

# --- Limits ---
MIN_FREE_DISK_GB=5
VERIFY_HASH=false
STALE_JOB_TIMEOUT_SEC=3600
FILESTER_STORAGE_PAUSE_PCT=95

# --- Retries ---
DOWNLOAD_MAX_RETRIES=5
UPLOAD_MAX_RETRIES=5
UPLOAD_RETRY_DELAY_SEC=30
DISCOVERY_DELAY_SEC=2

# --- VPN (optional, use docker-compose.vpn.yml) ---
VPN_ENABLED=false
PIA_OPENVPN_USER=
PIA_OPENVPN_PASSWORD=
PIA_SERVER_REGION=Netherlands

# --- Dashboard ---
DASHBOARD_PORT=8080
DASHBOARD_BIND_PORT=8080
LOG_LEVEL=INFO
WORKER_POLL_INTERVAL_SEC=5
HEARTBEAT_INTERVAL_SEC=30
TZ=UTC
