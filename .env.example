# =============================================================================
# Migradora — Gofile → Filester (minimal)
# Premium transfer account (#2) reads shared folder links from source account (#1).
# Subscription or Pay-As-You-Go both work — same API token from myProfile.
# =============================================================================

# --- Gofile (premium transfer account #2) ---
# Token from https://gofile.io/myProfile (subscription or PAYG account)
GOFILE_TOKEN=
# Comma-separated shared folder URLs from your source account (account #1)
GOFILE_FOLDER_URLS=
# Only if folders are password-protected
GOFILE_PASSWORD=

# --- Filester destination ---
FILESTER_API_KEY=
FILESTER_API_BASE=https://u1.filester.me
FILESTER_ROOT_FOLDER_NAME=
# Optional: Filester folder identifier for an existing root folder (from folder URL)
FILESTER_ROOT_FOLDER_ID=
FILESTER_MAX_FILE_BYTES=10200547328

# --- Paths (container paths; mapped in docker-compose) ---
DOWNLOAD_DIR=/data/downloads
STATE_DIR=/data/state
LOG_DIR=/data/logs

# --- Limits ---
MIN_FREE_DISK_GB=5
STALE_JOB_TIMEOUT_SEC=3600
# 0 = disabled (Filester ~10 GB limit is per-file, not total account storage)
FILESTER_STORAGE_PAUSE_PCT=0

# --- Retries ---
DOWNLOAD_MAX_RETRIES=5
DOWNLOAD_RETRY_DELAY_SEC=30
UPLOAD_MAX_RETRIES=5
UPLOAD_RETRY_DELAY_SEC=30
DISCOVERY_DELAY_SEC=2

# --- Web dashboard ---
# Port on host and inside container (change both by setting this once)
WEBUI_PORT=8080
LOG_LEVEL=INFO
WORKER_POLL_INTERVAL_SEC=5
TZ=UTC
